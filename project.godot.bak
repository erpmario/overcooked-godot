; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Overcooked-Godot"
run/main_scene="res://Scenes/Game.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Inputs="*uid://ceoijp35hn2ms"
Globals="*uid://cek3p3md6pcb0"

[display]

window/size/viewport_width=315
window/size/viewport_height=195
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="Overcooked AI"

[editor]

naming/node_name_num_separator=2
naming/default_signal_callback_name="_on_{nodeName}_{signalName}"
naming/default_signal_callback_to_self_name="_on_{signalName}"
naming/scene_name_casing=1
naming/script_name_casing=1

